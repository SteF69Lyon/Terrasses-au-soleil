---
import type { FaqEntry } from '@/lib/gemini';
export interface Props { items: FaqEntry[] }
const { items } = Astro.props;
---
{items.length > 0 && (
  <section>
    <h2>Questions fréquentes</h2>
    {items.map((f) => (
      <details class="faq-item">
        <summary>{f.question}</summary>
        <p>{f.answer}</p>
      </details>
    ))}
  </section>
)}
